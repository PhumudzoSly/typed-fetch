{
  "registryPath": ".typed-fetch/registry.json",
  "generatedPath": "generated/typed-fetch.d.ts",
  "include": [],
  "exclude": [],
  "dynamicSegmentPatterns": [
    "numeric",
    "uuid",
    "hash"
  ],
  "maxDepth": 8,
  "maxArraySample": 32,
  "ignoreFieldNames": [
    "password",
    "token",
    "secret",
    "authorization"
  ],
  "strictPrivacyMode": true,
  "observerMode": "auto"
}
