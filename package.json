{
  "name": "@phumudzo/typed-fetch",
  "version": "0.2.1",
  "description": "Privacy-first status-aware typed fetch with type generation from response shapes",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    },
    "./adapters/generic": {
      "types": "./dist/adapters/generic.d.ts",
      "default": "./dist/adapters/generic.js"
    },
    "./adapters/hono": {
      "types": "./dist/adapters/hono.d.ts",
      "default": "./dist/adapters/hono.js"
    },
    "./adapters/next": {
      "types": "./dist/adapters/next.d.ts",
      "default": "./dist/adapters/next.js"
    }
  },
  "peerDependencies": {
    "hono": ">=3",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "typed-fetch": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "init": "node dist/cli.js init",
    "generate": "node dist/cli.js generate",
    "check": "node dist/cli.js check",
    "clean": "node dist/cli.js clean",
    "watch": "node dist/cli.js watch",
    "export": "node dist/cli.js export",
    "import": "node dist/cli.js import",
    "test": "pnpm run build && node --test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PhumudzoSly/typed-fetch"
  },
  "keywords": [
    "fetch",
    "typescript",
    "type-safe",
    "http",
    "typegen",
    "privacy",
    "status-aware"
  ],
  "author": "Phumudzo",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.1",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/picomatch": "^4.0.3",
    "@types/react": "^18.0.0",
    "@types/react-test-renderer": "^18.0.0",
    "react": "^18.3.1",
    "react-test-renderer": "^18.3.1",
    "typescript": "^5.8.2"
  }
}
