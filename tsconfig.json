{
    "compilerOptions": {
        "target": "es2020",
        "lib": ["es2020", "dom", "dom.iterable"],
        "types": ["node"],
        "module": "commonjs",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "rootDir": "./src",
        "outDir": "./dist",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true
    },
    "include": [
        "src/**/*.ts"
    ]
}
